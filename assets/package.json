{
    "name": "@makraz/ux-editorjs",
    "description": "Symfony UX bundle to use Editor.js block-style editor",
    "type": "module",
    "version": "1.0.0",
    "license": "MIT",
    "files": [
        "dist"
    ],
    "main": "dist/controller.js",
    "types": "dist/controller.d.ts",
    "repository": {
        "type": "git",
        "url": "https://github.com/makraz/ux-editorjs"
    },
    "symfony": {
        "controllers": {
            "editorjs": {
                "main": "dist/controller.js",
                "webpackMode": "eager",
                "fetch": "eager",
                "enabled": true
            }
        },
        "importmap": {
            "@hotwired/stimulus": "^3.0.0",
            "@editorjs/editorjs": "^2.30.0",
            "@editorjs/header": "^2.8.0",
            "@editorjs/list": "^2.0.0",
            "@editorjs/paragraph": "^2.11.0",
            "@editorjs/image": "^2.9.0",
            "@editorjs/code": "^2.9.0",
            "@editorjs/delimiter": "^1.4.0",
            "@editorjs/quote": "^2.7.0",
            "@editorjs/warning": "^1.4.0",
            "@editorjs/table": "^2.4.0",
            "@editorjs/embed": "^2.7.0",
            "@editorjs/marker": "^1.4.0",
            "@editorjs/inline-code": "^1.5.0",
            "@editorjs/checklist": "^1.6.0",
            "@editorjs/link": "^2.6.0",
            "@editorjs/raw": "^2.5.0",
            "@editorjs/underline": "^1.1.0"
        }
    },
    "peerDependencies": {
        "@hotwired/stimulus": "^3.0.0",
        "@editorjs/editorjs": "^2.30.0"
    },
    "devDependencies": {
        "@babel/cli": "^7.20.7",
        "@babel/core": "^7.20.12",
        "@babel/preset-env": "^7.20.2",
        "@babel/preset-typescript": "^7.18.6",
        "@hotwired/stimulus": "^3.2.1",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "@editorjs/editorjs": "^2.30.0",
        "@editorjs/header": "^2.8.0",
        "@editorjs/list": "^2.0.0",
        "@editorjs/paragraph": "^2.11.0",
        "@editorjs/image": "^2.9.0",
        "@editorjs/code": "^2.9.0",
        "@editorjs/delimiter": "^1.4.0",
        "@editorjs/quote": "^2.7.0",
        "@editorjs/warning": "^1.4.0",
        "@editorjs/table": "^2.4.0",
        "@editorjs/embed": "^2.7.0",
        "@editorjs/marker": "^1.4.0",
        "@editorjs/inline-code": "^1.5.0",
        "@editorjs/checklist": "^1.6.0",
        "@editorjs/link": "^2.6.0",
        "@editorjs/raw": "^2.5.0",
        "@editorjs/underline": "^1.1.0"
    },
    "scripts": {
        "build": "babel src --extensions .ts -d dist",
        "watch": "babel src --out-dir dist --source-maps --watch --extensions '.ts,.js'"
    }
}
